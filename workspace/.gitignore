# Private/local workspace payloads. Keep only the scaffold README files tracked
# so a fresh clone preserves the recovery map, but never commit restored
# contents or nested payload README files.
/private/**
!/private/
!/private/README.md
!/private/archives/
!/private/archives/README.md
!/private/backups/
!/private/backups/README.md
!/private/builds/
!/private/builds/README.md
!/private/builds/boot_images/
!/private/builds/boot_images/README.md
!/private/builds/helpers/
!/private/builds/helpers/README.md
!/private/builds/ramdisks/
!/private/builds/ramdisks/README.md
!/private/builds/native-init/
!/private/builds/native-init/README.md
!/private/builds/wifi/
!/private/builds/wifi/README.md
!/private/device-dumps/
!/private/device-dumps/README.md
!/private/inputs/
!/private/inputs/README.md
!/private/inputs/boot_images/
!/private/inputs/boot_images/README.md
!/private/inputs/external_tools/
!/private/inputs/external_tools/README.md
!/private/inputs/firmware/
!/private/inputs/firmware/README.md
!/private/inputs/kernel_source/
!/private/inputs/kernel_source/README.md
!/private/inputs/toolchains/
!/private/inputs/toolchains/README.md
!/private/raw-logs/
!/private/raw-logs/README.md
!/private/scratch/
!/private/scratch/README.md
!/private/secrets/
!/private/secrets/README.md

# Public workspace guardrails. Public files are tracked by default, but these
# extensions/patterns are treated as raw, private, or oversized unless manually
# reviewed and renamed/redacted.
/public/**/*.img
/public/**/*.mbn
/public/**/*.bin
/public/**/*.cpio
/public/**/*.dtb
/public/**/*.dtbo
/public/**/*.ko
/public/**/*.o
/public/**/*.a
/public/**/*.so
/public/**/*.log
/public/**/*.raw
/public/**/*.pcap
/public/**/*.cap
/public/**/*.zip
/public/**/*.tgz
/public/**/*.tar
/public/**/*.tar.gz
/public/**/*.zst
/public/**/*secret*
/public/**/*private*
/public/**/*credential*
/public/**/*supplicant*
/public/**/*lease*

# Generated native-init outputs inside the public current-source tree. Source
# files stay tracked; rebuilt binaries must stay ignored/private.
/public/src/native-init/a90_sleep
/public/src/native-init/init_v*
!/public/src/native-init/init_v*.c
/public/src/native-init/helpers/a90_android_execns_probe
/public/src/native-init/helpers/a90_cpustress
/public/src/native-init/helpers/a90_fwpathctl
/public/src/native-init/helpers/a90_icnssctl
/public/src/native-init/helpers/a90_longsoak
/public/src/native-init/helpers/a90_qrtr_probe
/public/src/native-init/helpers/a90_rshell
/public/src/native-init/helpers/*_v[0-9]*
!/public/src/native-init/helpers/*.c

# Historical stage3 archive keeps source and compatibility symlinks, not copied
# generated ELF payloads. Build outputs belong under workspace/private/builds/.
/public/archive/stage3/linux_init/init
/public/archive/stage3/linux_init/init_v*
!/public/archive/stage3/linux_init/init_v*.c
/public/archive/stage3/linux_init/a90_sleep
/public/archive/stage3/linux_init/helpers/a90_android_execns_probe*
!/public/archive/stage3/linux_init/helpers/a90_android_execns_probe.c
/public/archive/stage3/linux_init/helpers/a90_cpustress
/public/archive/stage3/linux_init/helpers/a90_fwpathctl
/public/archive/stage3/linux_init/helpers/a90_icnssctl
/public/archive/stage3/linux_init/helpers/a90_longsoak
/public/archive/stage3/linux_init/helpers/a90_qrtr_probe
/public/archive/stage3/linux_init/helpers/a90_rshell
