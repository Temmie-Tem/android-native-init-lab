+		&head->buf[s22_fyg8_e1_state.proof_pos];
+	if (memcmp(record->header, s22_fyg8_e1_state.header,
+		   sizeof(record->header)) ||
+			!s22_fyg8_e1_build_slot(&active,
+				s22_fyg8_e1_state.active_slot,
+				s22_fyg8_e1_state.generation,
+				s22_fyg8_e1_state.stage,
+				S22_FYG8_E1_PROGRESS,
