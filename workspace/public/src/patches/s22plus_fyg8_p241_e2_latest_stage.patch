+	if (!s22_fyg8_e1_build_slot(&next, next_slot,
+			s22_fyg8_e1_state.generation + 1U,
+			request.stage, request.outcome, request.item_index,
+			le16_to_cpu(request.detail), s22_fyg8_e1_state.header))
+		return -EKEYREJECTED;
+	memcpy(&prospective, record, sizeof(prospective));
+	memcpy(&prospective.slots[next_slot], &next, sizeof(next));
+	if (!s22_fyg8_e1_record_families_allowed((const u8 *)&prospective))
+		return -EKEYREJECTED;
+
+	memset(&record->slots[next_slot].commit_crc, 0,
+	       sizeof(record->slots[next_slot].commit_crc));
+	__flush_dcache_area(&record->slots[next_slot].commit_crc,
+			    sizeof(record->slots[next_slot].commit_crc));
+	smp_wmb();
+	memcpy(&record->slots[next_slot], &next,
+	       offsetof(struct s22_fyg8_e1_slot, commit_crc));
+	__flush_dcache_area(&record->slots[next_slot],
+			    offsetof(struct s22_fyg8_e1_slot, commit_crc));
+	smp_wmb();
+	if (!s22_fyg8_e1_header_matches(head) ||
+			memcmp(record->header, s22_fyg8_e1_state.header,
+			       sizeof(record->header)) ||
+			memcmp(&record->slots[s22_fyg8_e1_state.active_slot],
+			       &active, sizeof(active)))
+		return -ESTALE;
+	memcpy(&record->slots[next_slot].commit_crc, &next.commit_crc,
+	       sizeof(next.commit_crc));
+	__flush_dcache_area(&record->slots[next_slot].commit_crc,
+			    sizeof(record->slots[next_slot].commit_crc));
+	smp_wmb();
+	if (!s22_fyg8_e1_header_matches(head) ||
+			memcmp(record->header, s22_fyg8_e1_state.header,
+			       sizeof(record->header)) ||
+			memcmp(&record->slots[next_slot], &next, sizeof(next)))
+		return -ESTALE;
+
+	s22_fyg8_e1_state.active_slot = next_slot;
+	s22_fyg8_e1_state.generation++;
+	s22_fyg8_e1_state.stage = request.stage;
+	s22_fyg8_e1_state.item_index = request.item_index;
+	s22_fyg8_e1_state.terminal =
+		request.outcome != S22_FYG8_E1_PROGRESS;
+	*position += count;
+	return count;
