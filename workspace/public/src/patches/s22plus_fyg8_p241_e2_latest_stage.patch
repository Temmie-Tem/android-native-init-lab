diff --git a/kernel_platform/common/init/Kconfig b/kernel_platform/common/init/Kconfig
--- a/kernel_platform/common/init/Kconfig
+++ b/kernel_platform/common/init/Kconfig
@@ -2443,5 +2443,39 @@ config ARCH_HAS_SYNC_CORE_BEFORE_USERMODE
 config ARCH_HAS_SYSCALL_WRAPPER
 	def_bool n
 
+config S22PLUS_FYG8_E1_LATEST_STAGE
+	bool "Samsung S22+ FYG8 compact E1 latest-stage evidence"
+	depends on OF
+	select CRC32
+	default n
+	help
+	  Publish one 45-byte candidate-bound E1A/E1B/E2 A/B checkpoint in the
+	  Samsung retained log. The write-only proc API accepts only PID 1,
+	  fixed version-2 requests, and exact monotonic profile stages.
+
+config S22PLUS_FYG8_E1_PROFILE
+	int "S22+ FYG8 compact E1 profile"
+	depends on S22PLUS_FYG8_E1_LATEST_STAGE
+	range 1 3
+	default 1
+	help
+	  Select E1A (1), E1B (2), or E2 (3). Candidate construction binds this
+	  value to the userspace runtime and immutable run manifest.
+
+config S22PLUS_FYG8_E1_RUN_ID_HEX
+	string "S22+ FYG8 compact E1 128-bit run ID"
+	depends on S22PLUS_FYG8_E1_LATEST_STAGE
+	default ""
+	help
+	  Exactly 32 lowercase hexadecimal digits. Empty or malformed values
+	  make the evidence hook fail closed without writing retained memory.
+
+config S22PLUS_FYG8_E1_UNSAT_TAG_HEX
+	string "S22+ FYG8 compact E1 128-bit UNSAT tag"
+	depends on S22PLUS_FYG8_E1_LATEST_STAGE
+	default ""
+	help
+	  Candidate-specific 32-digit tag derived by the reviewed host model.
+
 source "init/Kconfig.gki"
 source "init/Kconfig.gki-debug"
