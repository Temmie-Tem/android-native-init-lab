diff --git a/kernel_platform/common/arch/arm64/configs/gki_defconfig b/kernel_platform/common/arch/arm64/configs/gki_defconfig
--- a/kernel_platform/common/arch/arm64/configs/gki_defconfig
+++ b/kernel_platform/common/arch/arm64/configs/gki_defconfig
@@ -737,6 +737,7 @@ CONFIG_CRYPTO_FIPS=y
 
 
 # CONFIG_RKP_TEST is not set
+CONFIG_S22PLUS_FYG8_RETAINED_WITNESS=y
 
 
 
diff --git a/kernel_platform/common/init/Kconfig b/kernel_platform/common/init/Kconfig
--- a/kernel_platform/common/init/Kconfig
+++ b/kernel_platform/common/init/Kconfig
@@ -2443,5 +2443,13 @@ config ARCH_HAS_SYNC_CORE_BEFORE_USERMODE
 config ARCH_HAS_SYSCALL_WRAPPER
 	def_bool n
 
+config S22PLUS_FYG8_RETAINED_WITNESS
+	bool "Samsung S22+ FYG8 retained init witness"
+	default n
+	help
+	  Append one build-bound marker to the FYG8 Samsung kernel log reserved
+	  memory after PID 1 successfully accepts /init. This is a narrow research
+	  witness for SM-S906N S906NKSS7FYG8 and must remain disabled elsewhere.
+
 source "init/Kconfig.gki"
 source "init/Kconfig.gki-debug"
diff --git a/kernel_platform/common/init/main.c b/kernel_platform/common/init/main.c
--- a/kernel_platform/common/init/main.c
+++ b/kernel_platform/common/init/main.c
@@ -1376,6 +1376,54 @@ static int run_init_process(const char *init_filename)
 	return kernel_execve(init_filename, argv_init, envp_init);
 }
 
+#ifdef CONFIG_S22PLUS_FYG8_RETAINED_WITNESS
+#define S22PLUS_FYG8_LOG_BASE		0x800200000ULL
+#define S22PLUS_FYG8_LOG_SIZE		0x200000U
+#define S22PLUS_FYG8_LOG_MAGIC		0x4d474f4cU
+
+struct s22plus_fyg8_log_head {
+	u32 boot_cnt;
+	u32 magic;
+	u32 idx;
+	u32 prev_idx;
+	char buf[];
+};
+
+static void s22plus_fyg8_record_init_exec(const char *init_filename)
+{
+	static const char marker[] =
+		"\n[[S22R4W1B|id=36dc5462adedcf136176f2ddcfee08a8|"
+		"phase=DIRECT_INIT_EXEC_ACCEPTED|pid=1|path=/init]]\n";
+	struct s22plus_fyg8_log_head *head;
+	size_t payload_size = S22PLUS_FYG8_LOG_SIZE - sizeof(*head);
+	size_t marker_size = sizeof(marker) - 1;
+	size_t first;
+	u32 idx;
+	size_t pos;
+
+	if (strcmp(init_filename, "/init") || task_pid_nr(current) != 1)
+		return;
+
+	head = phys_to_virt((phys_addr_t)S22PLUS_FYG8_LOG_BASE);
+	if (READ_ONCE(head->magic) != S22PLUS_FYG8_LOG_MAGIC) {
+		pr_warn("S22R4W1B retained witness refused invalid log magic\n");
+		return;
+	}
+
+	idx = READ_ONCE(head->idx);
+	pos = idx % payload_size;
+	first = min(marker_size, payload_size - pos);
+	memcpy(&head->buf[pos], marker, first);
+	if (marker_size != first)
+		memcpy(head->buf, marker + first, marker_size - first);
+	smp_wmb();
+	WRITE_ONCE(head->idx, idx + marker_size);
+	pr_info("S22R4W1B retained witness appended after /init exec acceptance\n");
+}
+#else
+static inline void s22plus_fyg8_record_init_exec(const char *init_filename) { }
+#endif
+
 static int try_to_run_init_process(const char *init_filename)
 {
 	int ret;
@@ -1465,6 +1513,7 @@ static int __ref kernel_init(void *unused)
 	if (ramdisk_execute_command) {
 		ret = run_init_process(ramdisk_execute_command);
 		if (!ret) {
+			s22plus_fyg8_record_init_exec(ramdisk_execute_command);
 #ifdef CONFIG_RKP
 			rkp_deferred_init();
 #endif
