+config S22PLUS_FYG8_PID1_SAME_RING_DISCRIMINATOR
+	bool "Samsung S22+ FYG8 PID 1 same-ring discriminator"
+	default n
+	help
+	  Write one candidate-bound retained record after PID 1 accepts /init.
+	  Use the established 45-byte entry/userspace slot when it fits, or a
+	  24-byte diagnostic record when only that shorter prefix is visible.
+	  This option is specific to SM-S906N FYG8 and exposes no command shell.
+
 source "init/Kconfig.gki"
