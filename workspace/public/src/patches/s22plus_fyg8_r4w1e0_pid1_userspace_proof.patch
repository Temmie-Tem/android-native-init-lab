diff --git a/kernel_platform/common/arch/arm64/configs/gki_defconfig b/kernel_platform/common/arch/arm64/configs/gki_defconfig
--- a/kernel_platform/common/arch/arm64/configs/gki_defconfig
+++ b/kernel_platform/common/arch/arm64/configs/gki_defconfig
@@ -737,6 +737,7 @@ CONFIG_CRYPTO_FIPS=y
 
 
 # CONFIG_RKP_TEST is not set
+CONFIG_S22PLUS_FYG8_PID1_USERSPACE_PROOF=y
 
 
 
diff --git a/kernel_platform/common/init/Kconfig b/kernel_platform/common/init/Kconfig
--- a/kernel_platform/common/init/Kconfig
+++ b/kernel_platform/common/init/Kconfig
@@ -2443,5 +2443,14 @@ config ARCH_HAS_SYNC_CORE_BEFORE_USERMODE
 config ARCH_HAS_SYSCALL_WRAPPER
 	def_bool n
 
+config S22PLUS_FYG8_PID1_USERSPACE_PROOF
+	bool "Samsung S22+ FYG8 PID 1 userspace proof"
+	default n
+	help
+	  Write one compact retained entry proof after PID 1 accepts /init, then
+	  replace that exact slot only when PID 1 submits the build-bound first
+	  userspace checkpoint. This diagnostic option is specific to SM-S906N
+	  FYG8 and does not expose a general command channel.
+
 source "init/Kconfig.gki"
 source "init/Kconfig.gki-debug"
diff --git a/kernel_platform/common/init/main.c b/kernel_platform/common/init/main.c
--- a/kernel_platform/common/init/main.c
+++ b/kernel_platform/common/init/main.c
@@ -91,6 +91,7 @@
 #include <linux/kcsan.h>
 #include <linux/init_syscalls.h>
 #include <linux/stackdepot.h>
+#include <linux/uaccess.h>
 
 #include <asm/io.h>
 #include <asm/setup.h>
@@ -1376,6 +1377,150 @@ static int run_init_process(const char *init_filename)
 	return kernel_execve(init_filename, argv_init, envp_init);
 }
 
+#ifdef CONFIG_S22PLUS_FYG8_PID1_USERSPACE_PROOF
+#define S22PLUS_FYG8_P1U_LOG_BASE	0x800200000ULL
+#define S22PLUS_FYG8_P1U_LOG_SIZE	0x200000U
+#define S22PLUS_FYG8_P1U_LOG_MAGIC	0x4d474f4cU
+#define S22PLUS_FYG8_P1U_PROOF_SIZE	45U
+#define S22PLUS_FYG8_P1U_REQUEST_SIZE	32U
+
+struct s22plus_fyg8_p1u_log_head {
+	u32 boot_cnt;
+	u32 magic;
+	u32 idx;
+	u32 prev_idx;
+	char buf[];
+};
+
+struct s22plus_fyg8_p1u_state {
+	bool ready;
+	bool userspace_proven;
+	u32 seed_idx;
+	u32 seed_boot_cnt;
+	size_t proof_pos;
+};
+
+static struct s22plus_fyg8_p1u_state s22plus_fyg8_p1u_state;
+
+static const char s22plus_fyg8_p1u_entry[] =
+	"\n[[S22P1U|ba234c7de4105b2a23222436284605f2]]\n";
+static const char s22plus_fyg8_p1u_userspace[] =
+	"\n[[S22P1U|ec8d029b05288644bbe7b5f7c7af190c]]\n";
+static const u8 s22plus_fyg8_p1u_request[S22PLUS_FYG8_P1U_REQUEST_SIZE] = {
+	0x53, 0x32, 0x32, 0x51, 0x01, 0x01, 0x10, 0x00,
+	0x00, 0x00, 0x00, 0x00, 0x64, 0x55, 0x4e, 0x84,
+	0x69, 0x38, 0x58, 0x78, 0xc5, 0xbf, 0x8d, 0x57,
+	0xc4, 0x4e, 0xde, 0xea, 0xfd, 0x11, 0x8a, 0x62,
+};
+
+static struct s22plus_fyg8_p1u_log_head *s22plus_fyg8_p1u_head(void)
+{
+	return phys_to_virt((phys_addr_t)S22PLUS_FYG8_P1U_LOG_BASE);
+}
+
+static bool s22plus_fyg8_p1u_header_unchanged(
+		struct s22plus_fyg8_p1u_log_head *head)
+{
+	return READ_ONCE(head->magic) == S22PLUS_FYG8_P1U_LOG_MAGIC &&
+		READ_ONCE(head->idx) == s22plus_fyg8_p1u_state.seed_idx &&
+		READ_ONCE(head->boot_cnt) ==
+			s22plus_fyg8_p1u_state.seed_boot_cnt;
+}
+
+static bool s22plus_fyg8_p1u_store(
+		struct s22plus_fyg8_p1u_log_head *head, const char *proof)
+{
+	char *slot = &head->buf[s22plus_fyg8_p1u_state.proof_pos];
+
+	memcpy(slot, proof, S22PLUS_FYG8_P1U_PROOF_SIZE);
+	smp_wmb();
+	return !memcmp(slot, proof, S22PLUS_FYG8_P1U_PROOF_SIZE);
+}
+
+static void s22plus_fyg8_p1u_record_entry(const char *init_filename)
+{
+	struct s22plus_fyg8_p1u_log_head *head;
+	size_t payload_size = S22PLUS_FYG8_P1U_LOG_SIZE - sizeof(*head);
+	size_t cursor;
+	u32 seed_idx;
+
+	memset(&s22plus_fyg8_p1u_state, 0,
+	       sizeof(s22plus_fyg8_p1u_state));
+	if (strcmp(init_filename, "/init") || task_pid_nr(current) != 1)
+		return;
+	head = s22plus_fyg8_p1u_head();
+	seed_idx = READ_ONCE(head->idx);
+	if (READ_ONCE(head->magic) != S22PLUS_FYG8_P1U_LOG_MAGIC ||
+			seed_idx < payload_size)
+		return;
+	cursor = seed_idx % payload_size;
+	s22plus_fyg8_p1u_state.seed_idx = seed_idx;
+	s22plus_fyg8_p1u_state.seed_boot_cnt = READ_ONCE(head->boot_cnt);
+	s22plus_fyg8_p1u_state.proof_pos =
+		cursor >= S22PLUS_FYG8_P1U_PROOF_SIZE ?
+		cursor - S22PLUS_FYG8_P1U_PROOF_SIZE :
+		payload_size - S22PLUS_FYG8_P1U_PROOF_SIZE;
+	if (s22plus_fyg8_p1u_store(head, s22plus_fyg8_p1u_entry) &&
+			s22plus_fyg8_p1u_header_unchanged(head))
+		s22plus_fyg8_p1u_state.ready = true;
+}
+
+static ssize_t s22plus_fyg8_p1u_write(struct file *file,
+		const char __user *buffer, size_t count, loff_t *position)
+{
+	struct s22plus_fyg8_p1u_log_head *head;
+	u8 request[S22PLUS_FYG8_P1U_REQUEST_SIZE];
+	char *slot;
+
+	(void)file;
+	if (task_pid_nr(current) != 1)
+		return -EPERM;
+	if (!s22plus_fyg8_p1u_state.ready)
+		return -ENODEV;
+	if (s22plus_fyg8_p1u_state.userspace_proven)
+		return -EALREADY;
+	if (*position != 0 || count != sizeof(request))
+		return -EINVAL;
+	if (copy_from_user(request, buffer, sizeof(request)))
+		return -EFAULT;
+	if (memcmp(request, s22plus_fyg8_p1u_request, sizeof(request)))
+		return -EKEYREJECTED;
+	head = s22plus_fyg8_p1u_head();
+	slot = &head->buf[s22plus_fyg8_p1u_state.proof_pos];
+	if (!s22plus_fyg8_p1u_header_unchanged(head) ||
+			memcmp(slot, s22plus_fyg8_p1u_entry,
+			       S22PLUS_FYG8_P1U_PROOF_SIZE))
+		return -ESTALE;
+	if (!s22plus_fyg8_p1u_store(head, s22plus_fyg8_p1u_userspace))
+		return -ESTALE;
+	s22plus_fyg8_p1u_state.userspace_proven = true;
+	*position += count;
+	return count;
+}
+
+static const struct proc_ops s22plus_fyg8_p1u_ops = {
+	.proc_write = s22plus_fyg8_p1u_write,
+};
+
+static int __init s22plus_fyg8_p1u_proc_init(void)
+{
+	BUILD_BUG_ON(sizeof(s22plus_fyg8_p1u_entry) - 1 !=
+			S22PLUS_FYG8_P1U_PROOF_SIZE);
+	BUILD_BUG_ON(sizeof(s22plus_fyg8_p1u_userspace) - 1 !=
+			S22PLUS_FYG8_P1U_PROOF_SIZE);
+	BUILD_BUG_ON(sizeof(s22plus_fyg8_p1u_request) !=
+			S22PLUS_FYG8_P1U_REQUEST_SIZE);
+	if (!proc_create("s22_checkpoint", 0200, NULL,
+			&s22plus_fyg8_p1u_ops))
+		return -ENOMEM;
+	return 0;
+}
+late_initcall(s22plus_fyg8_p1u_proc_init);
+#else
+static inline void s22plus_fyg8_p1u_record_entry(
+		const char *init_filename) { }
+#endif
+
 static int try_to_run_init_process(const char *init_filename)
 {
 	int ret;
@@ -1465,6 +1610,7 @@ static int __ref kernel_init(void *unused)
 	if (ramdisk_execute_command) {
 		ret = run_init_process(ramdisk_execute_command);
 		if (!ret) {
+			s22plus_fyg8_p1u_record_entry(ramdisk_execute_command);
 #ifdef CONFIG_RKP
 			rkp_deferred_init();
 #endif
