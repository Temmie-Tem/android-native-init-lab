# =================================
# 대용량 파일 (절대 업로드 금지!)
# =================================

# Android NDK / Toolchains (5.1GB)
toolchains
toolchains/
android-ndk-*.zip

# Samsung 커널 소스와 빌드 결과
kernel_build/
SM-A908N_KOR_12_Opensource.zip

# =================================
# 백업 파일 (개인 데이터)
# =================================

# 모든 백업 디렉토리
backups
backups/
backups_*/
efs_backup/

# 백업 이미지 파일
backup_*.img
backup_*.tar
backup_*.tar.gz
*.img.bak

# =================================
# 빌드 아티팩트
# =================================

# Boot 이미지들
boot_image/*.img
boot_image/*.tar
boot_image/kernel
boot_image/ramdisk
!boot_image/README.md

# 커널 빌드 결과
*.img
*.dtb
*.dtbo
*.ko
*.o
*.a
*.so
Image
Image.gz
Image.gz-dtb
Image-dtb
vmlinux
System.map
Module.symvers
modules.order
modules.builtin

# Magisk 모듈 릴리스 압축본
scripts/magisk_module/releases/

# 로컬 패키지 다운로드
*.deb

# Initramfs 빌드
initramfs_build/busybox/
!initramfs_build/busybox/.gitkeep
initramfs_build/*.cpio
initramfs_build/*.cpio.gz
!initramfs_build/initramfs/
!initramfs_build/README.md

# Stage 3 native init 실험 산출물
stage3/linux_init/init_v*
!stage3/linux_init/init_v*.c
stage3/linux_init/a90_sleep
stage3/linux_init/helpers/a90_cpustress
stage3/linux_init/helpers/a90_rshell
stage3/linux_init/helpers/a90_longsoak
stage3/linux_init/helpers/a90_fwpathctl
stage3/linux_init/helpers/a90_icnssctl
stage3/linux_init/helpers/a90_android_execns_probe
stage3/linux_init/helpers/a90_qrtr_probe
# compiled helper binary snapshots — reproducible from *.c + build scripts,
# identity tracked via SHA256 in reports/CLAUDE.md; do not bloat git with them
stage3/linux_init/helpers/*_v[0-9]*
!stage3/linux_init/helpers/*.c
stage3/ramdisk_v*
stage3/ramdisk_v*/
stage3/ramdisk_v*.cpio

# 로컬 빌드/소스 캐시
aosp_source
aosp_source/
build_artifacts/
external_tools
external_tools/
out/

